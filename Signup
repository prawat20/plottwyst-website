const url = "https://script.google.com/macros/s/AKfycbyrwky0s3PgFGkdXompqR_b4lI7d2Bnl7rWPaoJRQTFyvD18LSQR7j5Jgunb943Z6I/exec"

async function submitEmail(email){

await fetch(url,{
method:"POST",
body:JSON.stringify({email:email})
})

}

document.querySelectorAll("form").forEach(form => {

form.addEventListener("submit", async e => {

e.preventDefault()

const email = form.querySelector("input").value

await submitEmail(email)

alert("Thanks! We'll notify you when PlotTwyst launches.")

form.reset()

})

})
